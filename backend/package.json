{
  "name": "h-codex",
  "version": "1.0.0",
  "description": "A semantic code search application using AST-based chunking and OpenAI embeddings",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "ingest": "bun run src/ingestion/index.ts",
    "search": "bun run src/search/index.ts",
    "db:setup": "bun run src/database/setup.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run src/database/migrate.ts",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "fix": "prettier --write \"src/**/*.ts\" && eslint . --ext .ts --fix"
  },
  "keywords": [
    "semantic-search",
    "code-search",
    "embeddings",
    "ast",
    "typescript"
  ],
  "author": "Htoo Pyae Lwin",
  "license": "MIT",
  "dependencies": {
    "@babel/parser": "^7.27.5",
    "@babel/traverse": "^7.27.4",
    "@babel/types": "^7.27.6",
    "@hono/zod-validator": "^0.7.0",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.2",
    "openai": "^5.6.0",
    "pg": "^8.16.2",
    "postgres": "^3.4.7",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/babel__traverse": "^7.20.7",
    "@types/bun": "^1.2.16",
    "@types/pg": "^8.15.4",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "drizzle-kit": "^0.31.1",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.5.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
